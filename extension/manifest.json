{
  "manifest_version": 3,
  "name": "My Memory",
  "version": "3.1.0",
  "description": "Capture and organize pages, selections, tweets, videos, and notes into your searchable personal memory.",
  "permissions": ["activeTab", "scripting", "storage", "contextMenus", "tabs"],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "My Memory",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["settings.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
